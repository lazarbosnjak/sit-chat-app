# JWT signing key.
# Must be Base64-encoded and long enough for HS512.
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZmdoaWprbG1ub3BxcnN0dXZ3eHl6QUJDREVGR0hJSktMTU5PUFFSUlNUVVZXWFlaMDE=

# PostgreSQL credentials for jdbc:postgresql://localhost:5432/svt.
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

# Backend HTTP port.
SERVER_PORT=8080

# Mail server settings. Defaults match application.yaml.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_FROM=no-reply@sitapp.local

# Frontend URL used when generating links, such as password reset links.
APP_FRONTEND_URL=http://localhost:4200

# Audio service integration.
AUDIO_SERVICE_BASE_URL=http://localhost:8082
# Must match AUDIO_INTERNAL_TOKEN in services/audio-service when token validation is enabled.
AUDIO_INTERNAL_TOKEN=
