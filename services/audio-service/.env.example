AUDIO_DATABASE_URL=postgres://postgres:postgres@localhost:5432/svt_audio?sslmode=disable
# DATABASE_URL is used only as a fallback when AUDIO_DATABASE_URL is empty.
DATABASE_URL=

# HTTP server address.
AUDIO_HTTP_ADDR=:8082

# Local directory where uploaded audio files are stored.
AUDIO_STORAGE_DIR=./data/audio

# Optional shared token expected in the X-Internal-Token header.
# Leave empty to disable token validation.
AUDIO_INTERNAL_TOKEN=

# Maximum upload size in bytes. Default: 26214400 (25 MiB).
AUDIO_MAX_UPLOAD_BYTES=26214400

# PostgreSQL pool and startup retry settings.
# AUDIO_DB_MAX_CONNECTIONS defaults to 5 when empty.
AUDIO_DB_MAX_CONNECTIONS=5
AUDIO_DB_CONNECT_TIMEOUT=30s
AUDIO_DB_RETRY_INTERVAL=2s
